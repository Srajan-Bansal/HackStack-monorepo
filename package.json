{
	"name": "HackStack",
	"private": true,
	"workspaces": ["apps/*", "packages/*", "packages/common/*"],
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"start": "turbo start",
		"lint": "turbo lint",
		"type-check": "turbo type-check",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"web": "turbo run dev --filter=!submission-webhook",
		"backend": "turbo run dev --filter=http-backend",
		"prisma:generate": "turbo run prisma:generate --filter=@repo/db",
		"prisma:migrate": "turbo run prisma:migrate --filter=@repo/db",
		"prisma:seedLanguage": "turbo run seedLanguage --filter=@repo/db",
		"prisma:seedProblem": "turbo run seedProblem --filter=@repo/db"
	},
	"devDependencies": {
		"prettier": "^3.2.5",
		"turbo": "^2.4.4",
		"typescript": "5.5.4"
	},
	"packageManager": "bun@1.2.0"
}