{
	"extends": "@repo/typescript-config/react-library.json",
	"compilerOptions": {
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": ".",
		"types": ["react", "react-dom", "node"],
		"paths": {
			"@workspace/ui/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
